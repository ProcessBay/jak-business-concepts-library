# Streamlit Cloud secrets — paste these into the "Secrets" textbox in the
# Streamlit Cloud app settings (Settings → Secrets). Do not commit a real
# secrets.toml to the repo.

# Kimi (Moonshot) — used for English synthesis. Cheap and fast.
KIMI_API_KEY = "sk-replace-me"
KIMI_BASE_URL = "https://api.moonshot.ai/v1"
KIMI_MODEL = "moonshot-v1-auto"

# OpenAI — used for Arabic synthesis (Kimi can't produce production-quality
# Arabic). When set, Arabic queries route here; English stays on Kimi.
# Without this key, Arabic falls back to Kimi (low quality, leaks CJK chars).
# gpt-4o-mini costs ~$0.001 per Arabic query.
OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-4o-mini"

# Per-browser-session quota on AI synthesis calls. Set to 0 to disable the cap.
SESSION_AI_LIMIT = "15"

# Emergency kill switch — set to "1" to force the deployed bot into local-only
# mode without redeploying. Useful if API costs spike.
DISABLE_AI = ""
