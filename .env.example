# Kimi (Moonshot) API config
# Get a key at: https://platform.moonshot.ai/console/api-keys
# IMPORTANT — the international endpoint is api.moonshot.ai, NOT .cn.
# The .cn endpoint will reject international keys with 401 Invalid Authentication.
KIMI_API_KEY=sk-replace-me

# Endpoint (default works without setting; override only for the .cn region)
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Synthesis model. Options:
#   moonshot-v1-auto  — fast direct answers (default, recommended)
#   moonshot-v1-32k   — same family, fixed 32k context
#   kimi-k2.6         — reasoning model (slower, more thorough, needs higher max_tokens)
KIMI_MODEL=moonshot-v1-auto

# Optional: Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
