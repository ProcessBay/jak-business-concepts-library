# Kimi (Moonshot) API config
# Get a key at: https://platform.moonshot.ai/console/api-keys
# IMPORTANT — the international endpoint is api.moonshot.ai, NOT .cn.
# The .cn endpoint will reject international keys with 401 Invalid Authentication.
KIMI_API_KEY=sk-replace-me

# Endpoint (default works without setting; override only for the .cn region)
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Synthesis model. Options:
#   moonshot-v1-auto  — fast direct answers (default, recommended)
#   moonshot-v1-32k   — same family, fixed 32k context
#   kimi-k2.6         — reasoning model (slower, more thorough, needs higher max_tokens)
KIMI_MODEL=moonshot-v1-auto

# Optional: Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ---------------------------------------------------------------------------
# Telemetry — Supabase Postgres logging of anonymized queries
# ---------------------------------------------------------------------------
# When SUPABASE_URL + SUPABASE_ANON_KEY are present, every query is logged to
# the `query_log` table (see supabase_schema.sql). When absent, telemetry is
# a silent no-op — the app runs identically.
#
# Setup (one-time):
#   1. Create a free Supabase project at https://supabase.com (no credit card).
#   2. In the project's SQL editor, paste & run supabase_schema.sql.
#   3. Settings → API → copy the Project URL and the `anon` public key below.
#      (Do NOT use the service_role key in the app — anon is write-only by
#      design; the RLS policy in the schema enforces this.)
#
# Privacy: no IP, no user agent, no user id. session_hash is a truncated
# one-way SHA256 of a UUID generated per browser session.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...replace-me

# Kill switch — set to 0 to disable logging without removing the keys above.
TELEMETRY_ENABLED=1

# Optional tag written into every row, useful for diffing pre/post a release.
APP_VERSION=2026-05-25
